{
  "name": "soul-bleach",
  "displayName": "灵境",
  "description": "A VS Code sidebar AI assistant for chatting with models and working with workspace files.",
  "version": "0.0.23",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "soul-bleach",
          "title": "灵境",
          "icon": "media/soul-bleach.svg"
        }
      ]
    },
    "views": {
      "soul-bleach": [
        {
          "type": "webview",
          "id": "soulBleachView",
          "name": "灵境"
        }
      ]
    },
    "commands": [
      {
        "command": "soul-bleach.helloWorld",
        "title": "灵境: Hello World"
      },
      {
        "command": "soul-bleach.run",
        "title": "灵境: Run Agent"
      },
      {
        "command": "soul-bleach.test",
        "title": "灵境: Agent Test"
      }
    ],
    "configuration": {
      "title": "灵境",
      "properties": {
        "soul-bleach.provider": {
          "type": "string",
          "default": "qwen",
          "enum": [
            "qwen",
            "zhipu-open",
            "zhipu-coding",
            "zai",
            "custom"
          ],
          "enumDescriptions": [
            "阿里云百炼 DashScope OpenAI-compatible 接口",
            "智谱开放平台 OpenAI-compatible 接口",
            "智谱 GLM Coding Plan OpenAI-compatible 接口",
            "Z.AI 国际站 OpenAI-compatible 接口",
            "自定义 OpenAI-compatible 接口，例如内网模型服务"
          ],
          "description": "模型服务商。modelPreset 选择跟随服务商时，会使用这里对应的默认接口和模型"
        },
        "soul-bleach.modelPreset": {
          "type": "string",
          "default": "provider-default",
          "enum": [
            "provider-default",
            "qwen3.7-plus",
            "qwen3.7-max",
            "qwen-plus",
            "glm-5.2",
            "glm-5.2-1m",
            "glm-5.1",
            "glm-5",
            "glm-4.7",
            "glm-4.7-flash",
            "custom"
          ],
          "enumDescriptions": [
            "跟随 provider 使用默认模型",
            "千问 Qwen3.7 Plus，走阿里云百炼 OpenAI-compatible 接口",
            "千问 Qwen3.7 Max，走阿里云百炼 OpenAI-compatible 接口",
            "千问 Qwen Plus，走阿里云百炼 OpenAI-compatible 接口",
            "智谱 GLM-5.2，优先走智谱开放平台接口",
            "智谱 GLM-5.2 1M 上下文，需要对应 Coding Plan 权限",
            "智谱 GLM-5.1",
            "智谱 GLM-5",
            "智谱 GLM-4.7，适合先验证 Coding Plan 是否可用",
            "智谱 GLM-4.7 Flash",
            "自定义模型，配合 baseUrl 和 model 手动填写"
          ],
          "description": "常用模型下拉选择。选择具体模型时会自动使用对应服务商默认接口；model 手动填写后会覆盖该选项"
        },
        "soul-bleach.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Chat Completions 完整接口地址。留空时使用 modelPreset 或 provider 的默认地址；自定义内网模型时填写类似 http://host:port/v1/chat/completions"
        },
        "soul-bleach.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key。内网无鉴权模型可以留空"
        },
        "soul-bleach.model": {
          "type": "string",
          "default": "",
          "description": "自定义模型名称。留空时使用 modelPreset 或 provider 的默认模型；填写后会覆盖下拉框选择"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "package": "vsce package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~22.19.21",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
